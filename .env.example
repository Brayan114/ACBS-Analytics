# Server Configuration
PORT=3000

# PostgreSQL Configuration
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/brawl_stars

# Brawl Stars API Settings
BRAWL_STARS_API_KEY=your_supercell_api_key_here

# Cron Settings
# Default: runs every 5 minutes
POLL_INTERVAL_CRON="*/5 * * * *"

# Target Player Tags (comma separated) to poll battle logs for
TARGET_PLAYER_TAGS="#2Y002LYY,#8YCCJ8JG"

{
  "name": "brawl-stars-platform",
  "version": "1.0.0",
  "description": "Brawl Stars elite competitive platform with event-driven database and manual drafting",
  "main": "dist/server.js",
  "scripts": {
    "build:backend": "tsc",
    "build:frontend": "vite build",
    "build": "tsc && vite build",
    "start": "node dist/server.js",
    "dev:backend": "ts-node-dev --respawn --transpile-only src/server.ts",
    "dev:frontend": "vite",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\""
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "lucide-react": "^0.378.0",
    "node-cron": "^3.0.3",
    "pg": "^8.11.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/express": "^4.17.21",
    "@types/node": "^20.12.12",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.11.6",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^8.2.2",
    "tailwindcss": "^4.0.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5",
    "vite": "^5.2.11"
  }
}
